YOUTUBE_API_KEY=your_google_api_key_here

# ProtonMail SMTP Settings
SMTP_SERVER=127.0.0.1 # Replace with Proton's SMTP server host
SMTP_PORT=587
SMTP_USERNAME=your_proton_username
SMTP_PASSWORD=your_proton_smtp_token

# Email routing
FROM_EMAIL=your_sending_address@yourdomain.com
TO_EMAIL=your_receiving_address@yourdomain.com
